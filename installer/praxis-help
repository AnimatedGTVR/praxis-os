#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR_PATH="${0%/*}"
        ;;
    *)
        SCRIPT_DIR_PATH="."
        ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR_PATH}" && pwd)"

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

praxis_load_core

DOC_ROOT="${PRAXIS_DOC_ROOT:-/usr/share/doc/praxis}"
REPO_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." 2>/dev/null && pwd || printf '%s\n' "")"

doc_file() {
    topic="$1"

    if [ -r "${DOC_ROOT}/${topic}" ]; then
        printf '%s\n' "${DOC_ROOT}/${topic}"
        return 0
    fi

    if [ -n "${REPO_ROOT}" ] && [ -r "${REPO_ROOT}/Documentation/${topic}" ]; then
        printf '%s\n' "${REPO_ROOT}/Documentation/${topic}"
        return 0
    fi

    if [ "${topic}" = "README.md" ] && [ -n "${REPO_ROOT}" ] && [ -r "${REPO_ROOT}/README.md" ]; then
        printf '%s\n' "${REPO_ROOT}/README.md"
        return 0
    fi

    return 1
}

show_doc() {
    topic="$1"
    file_path="$(doc_file "${topic}" || true)"

    if [ -z "${file_path}" ]; then
        printf 'missing Praxis doc: %s\n' "${topic}" >&2
        exit 1
    fi

    exec cat "${file_path}"
}

case "${1:-}" in
    install)
        show_doc "INSTALL.md"
        ;;
    qemu)
        show_doc "QEMU.md"
        ;;
    commands)
        show_doc "COMMANDS.md"
        ;;
    packages)
        show_doc "PACKAGES.md"
        ;;
    docs)
        show_doc "DOC.md"
        ;;
    pax)
        show_doc "PAX.md"
        ;;
    first-boot)
        show_doc "FIRST-BOOT.md"
        ;;
    troubleshooting)
        show_doc "TROUBLESHOOTING.md"
        ;;
    readme)
        show_doc "README.md"
        ;;
    -h|--help)
        ;;
    "")
        ;;
    *)
        printf 'unknown topic: %s\n' "${1}" >&2
        printf '%s\n' "available topics: install, qemu, commands, packages, docs, pax, first-boot, troubleshooting, readme" >&2
        exit 1
        ;;
esac

praxis_header "${PRAXIS_TAGLINE:-Praxis}"
printf '%s\n' "docs:"
printf '%s\n' "  praxis-help install"
printf '%s\n' "  praxis-help qemu"
printf '%s\n' "  praxis-help commands"
printf '%s\n' "  praxis-help packages"
printf '%s\n' "  praxis-help docs"
printf '%s\n' "  praxis-help pax"
printf '%s\n' "  praxis-help first-boot"
printf '%s\n' "  praxis-help troubleshooting"
printf '%s\n' "  praxis-help readme"
printf '\n'
printf '%s\n' "install stages:"
printf '%s\n' "  praxis-install --hostname <name> <target>"
printf '%s\n' "  mkinitrd <target>"
printf '%s\n' "  praxis-chroot <target>"
printf '%s\n' "  targetcheck <target>"
printf '\n'
printf '%s\n' "tools:"
printf '%s\n' "  lsblk  blkid  fdisk  parted  mkfs.vfat  mkfs.ext4"
printf '%s\n' "  preflight  praxis-status  praxis-disk-report"
printf '%s\n' "  praxis-netcheck  praxis-support  praxis-fetch"
