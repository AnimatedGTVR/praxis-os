#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR_PATH="${0%/*}"
        ;;
    *)
        SCRIPT_DIR_PATH="."
        ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR_PATH}" && pwd)"

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

TARGET_ROOT="${1:-}"
TARGET_HOSTNAME="unknown"

if [ -n "${TARGET_ROOT}" ] && [ -r "${TARGET_ROOT}/etc/hostname" ]; then
    TARGET_HOSTNAME="$(sed -n '1p' "${TARGET_ROOT}/etc/hostname")"
    [ -n "${TARGET_HOSTNAME}" ] || TARGET_HOSTNAME="unknown"
fi

praxis_header "Post-Install"
printf '%s\n' "Recommended next steps:"
printf '%s\n' "- run praxis-target-check ${TARGET_ROOT:-/mnt/praxis} before you reboot"
printf '%s\n' "- confirm the hostname in the target with: cat ${TARGET_ROOT:-/mnt/praxis}/etc/hostname"
printf '%s\n' "- sync the filesystem before unmounting"
printf '%s\n' "- unmount the EFI partition first, then the root filesystem"
printf '%s\n' "- boot the installed disk and run praxis-status"
printf '%s\n' "- use praxis-netcheck after first boot to confirm networking"
printf '%s\n' "- if you selected software bundles, inspect them with: cat ${TARGET_ROOT:-/mnt/praxis}/etc/praxis/packages.selected"
printf '%s\n' "- if you installed a desktop profile, try it later with: praxis-desktop list"
printf '\n'
if [ -n "${TARGET_ROOT}" ]; then
    printf 'Target root     %s\n' "${TARGET_ROOT}"
    printf 'Target hostname %s\n' "${TARGET_HOSTNAME}"
    printf '\n'
fi
printf '%s\n' "Useful commands:"
printf '%s\n' "- sync"
printf '%s\n' "- umount ${TARGET_ROOT:-/mnt/praxis}/boot"
printf '%s\n' "- umount ${TARGET_ROOT:-/mnt/praxis}"
printf '%s\n' "- reboot"
