#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR_PATH="${0%/*}"
        ;;
    *)
        SCRIPT_DIR_PATH="."
        ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR_PATH}" && pwd)"

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

TARGET_ROOT="${1:-}"

[ -n "${TARGET_ROOT}" ] || { printf 'usage: praxis-postinstall <target>\n' >&2; exit 1; }

STAGE_FILE="${TARGET_ROOT}/etc/praxis/install-stage"
if [ -r "${STAGE_FILE}" ]; then
    stage="$(head -n1 "${STAGE_FILE}" 2>/dev/null || true)"
    printf 'install-stage: %s\n' "${stage:-unknown}"
else
    printf 'install-stage: none\n'
fi

if [ -r "${TARGET_ROOT}/etc/hostname" ]; then
    printf 'hostname: %s\n' "$(head -n1 "${TARGET_ROOT}/etc/hostname")"
fi

if [ -r "${TARGET_ROOT}/etc/fstab" ]; then
    printf 'fstab: present\n'
else
    printf 'fstab: missing\n'
fi

if [ -f "${TARGET_ROOT}/boot/praxis/vmlinuz" ]; then
    printf 'vmlinuz: present\n'
else
    printf 'vmlinuz: missing\n'
fi

if [ -f "${TARGET_ROOT}/boot/praxis/initramfs.cpio.gz" ]; then
    printf 'initramfs: present\n'
else
    printf 'initramfs: missing\n'
fi
