#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR_PATH="${0%/*}"
        ;;
    *)
        SCRIPT_DIR_PATH="."
        ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR_PATH}" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "${SCRIPT_DIR}/.." 2>/dev/null && pwd || printf '%s\n' "")"
HOST_KERNEL="/lib/modules/$(uname -r 2>/dev/null || printf '%s\n' unknown)/vmlinuz"

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

TARGET_ROOT="${1:-}"
PASS_COUNT=0
WARN_COUNT=0
FAIL_COUNT=0

say_ok() {
    PASS_COUNT=$((PASS_COUNT + 1))
    printf '[ok] %s\n' "$1"
}

say_warn() {
    WARN_COUNT=$((WARN_COUNT + 1))
    printf '[warn] %s\n' "$1"
}

say_fail() {
    FAIL_COUNT=$((FAIL_COUNT + 1))
    printf '[fail] %s\n' "$1"
}

check_command() {
    if command -v "$1" >/dev/null 2>&1; then
        say_ok "command available: $1"
    else
        say_fail "missing command: $1"
    fi
}

check_optional_command() {
    if command -v "$1" >/dev/null 2>&1; then
        say_ok "command available: $1"
    else
        say_warn "optional command missing: $1"
    fi
}

check_one_command() {
    COMMAND_LABEL="$1"
    shift

    for COMMAND_CANDIDATE in "$@"; do
        if command -v "${COMMAND_CANDIDATE}" >/dev/null 2>&1; then
            say_ok "command available for ${COMMAND_LABEL}: ${COMMAND_CANDIDATE}"
            return 0
        fi
    done

    say_fail "missing command for ${COMMAND_LABEL}: $*"
}

check_file() {
    if [ -r "$1" ]; then
        say_ok "file present: $1"
    else
        say_fail "missing file: $1"
    fi
}

check_file_pair() {
    PRIMARY_PATH="$1"
    FALLBACK_PATH="$2"

    if [ -r "${PRIMARY_PATH}" ]; then
        say_ok "file present: ${PRIMARY_PATH}"
        return 0
    fi

    if [ -n "${FALLBACK_PATH}" ] && [ -r "${FALLBACK_PATH}" ]; then
        say_ok "file present: ${FALLBACK_PATH}"
        return 0
    fi

    say_fail "missing file: ${PRIMARY_PATH}"
}

praxis_header "preflight"

printf '%s\n' "Core commands"
printf '%s\n' "------------------------------------------------------------"
for cmd in praxis-help praxis-install targetcheck praxis-status praxis-disk-report blkid mount mountpoint gzip; do
    check_command "$cmd"
done
check_one_command "archive copy" bsdtar tar
check_one_command "initramfs creation" bsdtar cpio
for cmd in praxis-fetch praxis-netcheck praxis-support lsblk fdisk mkfs.vfat mke2fs bootctl fastfetch; do
    check_optional_command "$cmd"
done
printf '\n'

printf '%s\n' "Praxis payload"
printf '%s\n' "------------------------------------------------------------"
if [ -r "/usr/share/praxis/vmlinuz" ]; then
    say_ok "file present: /usr/share/praxis/vmlinuz"
elif [ -n "${REPO_ROOT}" ] && [ -r "${REPO_ROOT}/kernel/bzImage" ]; then
    say_ok "file present: ${REPO_ROOT}/kernel/bzImage"
elif [ -r "${HOST_KERNEL}" ]; then
    say_ok "file present: ${HOST_KERNEL}"
else
    say_fail "missing file: /usr/share/praxis/vmlinuz"
fi
check_file_pair /usr/share/praxis/limine.conf "${REPO_ROOT}/boot/limine.conf"
check_file_pair /etc/praxis/praxis.env "${REPO_ROOT}/config/praxis.env"
check_file_pair /usr/share/doc/praxis/DOC.md "${REPO_ROOT}/Documentation/DOC.md"
check_file_pair /usr/share/doc/praxis/INSTALL.md "${REPO_ROOT}/Documentation/INSTALL.md"
check_file_pair /usr/share/doc/praxis/COMMANDS.md "${REPO_ROOT}/Documentation/COMMANDS.md"
check_file_pair /usr/share/doc/praxis/PAX.md "${REPO_ROOT}/pax/spec/PAX.md"
printf '\n'

if [ -n "${TARGET_ROOT}" ]; then
    printf '%s\n' "Target mount check"
    printf '%s\n' "------------------------------------------------------------"
    if [ -d "${TARGET_ROOT}" ]; then
        say_ok "target path exists: ${TARGET_ROOT}"
    else
        say_fail "target path missing: ${TARGET_ROOT}"
    fi

    if praxis_is_mountpoint "${TARGET_ROOT}"; then
        say_ok "target root mounted: ${TARGET_ROOT}"
    else
        say_fail "target root not mounted: ${TARGET_ROOT}"
    fi

    if [ -d "${TARGET_ROOT}/boot" ]; then
        say_ok "target boot path exists: ${TARGET_ROOT}/boot"
    else
        say_fail "target boot path missing: ${TARGET_ROOT}/boot"
    fi

    if praxis_is_mountpoint "${TARGET_ROOT}/boot"; then
        say_ok "target boot mounted: ${TARGET_ROOT}/boot"
    else
        say_fail "target boot not mounted: ${TARGET_ROOT}/boot"
    fi
    printf '\n'
else
    printf '\n'
fi

printf '%s\n' "Summary"
printf '%s\n' "------------------------------------------------------------"
printf '[*] Passed: %s\n' "${PASS_COUNT}"
printf '[*] Warnings: %s\n' "${WARN_COUNT}"
printf '[*] Failures: %s\n' "${FAIL_COUNT}"

if [ "${FAIL_COUNT}" -eq 0 ]; then
    exit 0
fi

exit 1
