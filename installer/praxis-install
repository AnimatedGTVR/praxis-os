#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR="$(CDPATH= cd -- "${0%/*}" && pwd)"
        ;;
    *)
        SCRIPT_DIR="."
        ;;
esac

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

SOURCE_ROOT="${PRAXIS_SOURCE_ROOT:-/}"
TARGET_ROOT=""
TARGET_HOSTNAME="${PRAXIS_TARGET_HOSTNAME:-}"

while [ "$#" -gt 0 ]; do
    case "$1" in
        \\)
            ;;
        --hostname)
            shift
            [ "$#" -gt 0 ] || { printf 'missing hostname\n' >&2; exit 1; }
            TARGET_HOSTNAME="$1"
            ;;
        -h|--help)
            printf 'usage: praxis-install --hostname <name> <target>\n'
            exit 0
            ;;
        *)
            [ -z "${TARGET_ROOT}" ] || { printf 'usage: praxis-install --hostname <name> <target>\n' >&2; exit 1; }
            TARGET_ROOT="$1"
            ;;
    esac
    shift
done

[ -n "${TARGET_HOSTNAME}" ] || { printf 'hostname required\n' >&2; exit 1; }
[ -n "${TARGET_ROOT}" ] || { printf 'target required\n' >&2; exit 1; }

praxis_valid_hostname "${TARGET_HOSTNAME}" || { printf 'invalid hostname: %s\n' "${TARGET_HOSTNAME}" >&2; exit 1; }

case "${TARGET_ROOT}" in
    /*) ;;
    pacman|yay|paru)
        printf 'invalid target: %s\n' "${TARGET_ROOT}" >&2
        exit 1
        ;;
    *)
        printf 'target must be absolute path\n' >&2
        exit 1
        ;;
esac

[ "${TARGET_ROOT}" != "/" ] || { printf 'refusing install to /\n' >&2; exit 1; }

command -v gzip >/dev/null 2>&1 || { printf 'missing: gzip\n' >&2; exit 1; }
if ! command -v bsdtar >/dev/null 2>&1 && ! command -v tar >/dev/null 2>&1; then
    printf 'missing: tar\n' >&2; exit 1
fi
if ! command -v bsdtar >/dev/null 2>&1 && ! command -v cpio >/dev/null 2>&1; then
    printf 'missing: cpio\n' >&2; exit 1
fi

if [ "${PRAXIS_ALLOW_UNMOUNTED_TARGET:-0}" != "1" ]; then
    praxis_is_mountpoint "${TARGET_ROOT}" || { printf 'not mounted: %s\n' "${TARGET_ROOT}" >&2; exit 1; }
    praxis_is_mountpoint "${TARGET_ROOT}/boot" || { printf 'not mounted: %s/boot\n' "${TARGET_ROOT}" >&2; exit 1; }
fi

if [ "${PRAXIS_SKIP_BOOT_FSTYPE_CHECK:-0}" != "1" ] && [ "${PRAXIS_ALLOW_UNMOUNTED_TARGET:-0}" != "1" ]; then
    BOOT_FSTYPE="$(praxis_find_mount_fstype "${TARGET_ROOT}/boot" || true)"
    case "${BOOT_FSTYPE}" in
        vfat|fat32|fat16|fat|msdos) ;;
        *) printf 'boot must be vfat, got: %s\n' "${BOOT_FSTYPE:-unknown}" >&2; exit 1 ;;
    esac
fi

mkdir -p "${TARGET_ROOT}/etc/praxis"

if command -v bsdtar >/dev/null 2>&1; then
    if [ "${SOURCE_ROOT}" = "/" ]; then
        bsdtar -C "${SOURCE_ROOT}" \
            --exclude "./proc" --exclude "./sys" --exclude "./dev" \
            --exclude "./run" --exclude "./tmp" \
            --exclude ".${TARGET_ROOT}" \
            -cf - . | bsdtar -C "${TARGET_ROOT}" -xf -
    else
        bsdtar -C "${SOURCE_ROOT}" \
            --exclude "./proc" --exclude "./sys" --exclude "./dev" \
            --exclude "./run" --exclude "./tmp" \
            -cf - . | bsdtar -C "${TARGET_ROOT}" -xf -
    fi
else
    if [ "${SOURCE_ROOT}" = "/" ]; then
        tar -C "${SOURCE_ROOT}" \
            --exclude "./proc" --exclude "./sys" --exclude "./dev" \
            --exclude "./run" --exclude "./tmp" \
            --exclude ".${TARGET_ROOT}" \
            -cf - . | tar -C "${TARGET_ROOT}" -xf -
    else
        tar -C "${SOURCE_ROOT}" \
            --exclude "./proc" --exclude "./sys" --exclude "./dev" \
            --exclude "./run" --exclude "./tmp" \
            -cf - . | tar -C "${TARGET_ROOT}" -xf -
    fi
fi

praxis_write_identity_files "${TARGET_ROOT}" "${TARGET_HOSTNAME}"

printf 'rootfs\n' > "${TARGET_ROOT}/etc/praxis/install-stage"

cat > "${TARGET_ROOT}/etc/praxis/install" <<EOF
INSTALL_MODE=standard
INSTALL_DATE=$(date -u +%Y-%m-%dT%H:%M:%SZ)
INSTALL_HOSTNAME=${TARGET_HOSTNAME}
INSTALL_SOURCE_ROOT=${SOURCE_ROOT}
INSTALL_COMPLETE=0
EOF

sync
printf 'rootfs -> %s\n' "${TARGET_ROOT}"
