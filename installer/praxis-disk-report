#!/bin/sh

set -eu

case "$0" in
    */*)
        SCRIPT_DIR_PATH="${0%/*}"
        ;;
    *)
        SCRIPT_DIR_PATH="."
        ;;
esac

SCRIPT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR_PATH}" && pwd)"

if [ -n "${PRAXIS_LIB_ROOT:-}" ] && [ -r "${PRAXIS_LIB_ROOT}/common.sh" ]; then
    . "${PRAXIS_LIB_ROOT}/common.sh"
elif [ -r /usr/local/lib/praxis/common.sh ]; then
    . /usr/local/lib/praxis/common.sh
else
    . "${SCRIPT_DIR}/lib/common.sh"
fi

praxis_header "Disk Report"

INSTALL_DISK_COUNT=0
FIRST_INSTALL_DISK=""

if command -v lsblk >/dev/null 2>&1; then
    lsblk -o PATH,NAME,SIZE,TYPE,FSTYPE,LABEL,MOUNTPOINT,MODEL 2>/dev/null || lsblk
elif [ -r /proc/partitions ]; then
    printf '%s\n' "lsblk is not available; showing /proc/partitions."
    cat /proc/partitions
else
    printf '%s\n' "lsblk is not available."
fi

for PRAXIS_BLOCK in /sys/block/*; do
    [ -e "${PRAXIS_BLOCK}" ] || continue
    PRAXIS_BLOCK_NAME="${PRAXIS_BLOCK##*/}"
    case "${PRAXIS_BLOCK_NAME}" in
        sr*|loop*|ram*|zram*|dm-*) continue ;;
    esac
    INSTALL_DISK_COUNT=$((INSTALL_DISK_COUNT + 1))
    if [ -z "${FIRST_INSTALL_DISK}" ]; then
        FIRST_INSTALL_DISK="/dev/${PRAXIS_BLOCK_NAME}"
    fi
done

if [ "${INSTALL_DISK_COUNT}" -eq 0 ]; then
    printf '\n'
    printf '%s\n' "no writable disk detected"
else
    printf '\n'
    printf 'candidate: %s\n' "${FIRST_INSTALL_DISK}"
fi
